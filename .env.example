# ══════════════════════════════════════════════════
#  BangDet-MD Telegram Bot — Environment Variables
#  Salin file ini menjadi .env dan isi nilainya
# ══════════════════════════════════════════════════

# ── TELEGRAM BOT ──────────────────────────────────
# Dapatkan dari @BotFather di Telegram
BOT_TOKEN=

# ── PAKASIR PAYMENT GATEWAY ───────────────────────
# Dapatkan dari dashboard Pakasir (app.pakasir.com)
PAKASIR_PROJECT=
PAKASIR_API_KEY=

# ── WEBHOOK SERVER ────────────────────────────────
# Port lokal yang digunakan webhook server
WEBHOOK_PORT=25582

# URL publik lengkap tempat bot dapat diakses dari internet
# Contoh VPS    : https://yourdomain.com  atau  http://IP_VPS:PORT
# Contoh Ngrok  : https://xxxx.ngrok.io
# Contoh Tunnel : https://xxxx.trycloudflare.com
# Jika tidak diisi, endpoint tidak akan ditampilkan di log (tidak error)
WEBHOOK_PUBLIC_URL=

# ── BOT IDENTITY ──────────────────────────────────
# Nama toko yang tampil di semua pesan bot
STORE_NAME=BangDet-MD

# Telegram User ID admin utama (angka, cek via @userinfobot)
ADMIN_ID=

# ── LIVE NOTIFICATIONS (Opsional) ─────────────────
# ID Channel testi & log transaksi (bot harus jadi Admin di channel)
# Format: -100xxxxxxxxxx  atau  @usernameChannel
TESTI_CHANNEL_ID=
LOG_CHANNEL_ID=

# ── CUSTOMER SERVICE (Opsional) ───────────────────
# Username CS Telegram tanpa @ (contoh: BangDetCS)
CS_USERNAME=
